<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="UsageIq.Agent.Views.QuickAddWindow"
        Title="Usage IQ — Quick add"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="4" Background="{StaticResource BrandGradient}"/>

        <StackPanel Grid.Row="1" Margin="22,18,22,8">
            <TextBlock Text="Quick add" FontSize="18" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBlock Text="Jot a line — Usage IQ files it as a list item, reminder, or note for your family."
                       Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <TextBox x:Name="TextInput" Style="{StaticResource Field}"
                     KeyDown="OnInputKeyDown"
                     TextChanged="OnInputChanged"/>
            <TextBlock Text="e.g. milk  ·  remind me to call the dentist tomorrow 9am  ·  note: wifi code"
                       Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="2,6,0,0"/>

            <TextBlock x:Name="StatusText" Text="" Foreground="{StaticResource SevWarning}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource BgPanel}" Padding="22,12"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource GhostButton}"
                        Margin="0,0,10,0" Click="OnCancel"/>
                <Button x:Name="AddButton" Content="Add" Style="{StaticResource PrimaryButton}"
                        Width="110" Click="OnAdd"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
